# ── FastAPI + sync script ──────────────────────────────────────────────────

# HubSpot Private App token — required only for scripts/sync_to_hubspot.py.
# The API itself does not call HubSpot; it only reads hubspot_company_id
# from the local hubspot_account_map table in SQLite.
# Create a Private App at: HubSpot > Settings > Integrations > Private Apps
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here

# Your HubSpot portal ID — the number in any HubSpot URL after /contacts/.
# Used by the API to build Company record deep-links.
HUBSPOT_PORTAL_ID=your_hubspot_portal_id_here

# SQLAlchemy database URL. Defaults to SQLite if not set.
# Swap to a Postgres DSN when promoting to production:
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=sqlite:///data/churn.db

# ── Next.js dashboard (dashboard/.env.local) ───────────────────────────────

# Server-side URL used by Next.js Route Handlers to proxy requests to FastAPI.
# Never exposed to the browser.
FASTAPI_BASE_URL=http://127.0.0.1:8000

# Client-side URL used by the landing page warm-up ping.
# Must match FASTAPI_BASE_URL in value; the NEXT_PUBLIC_ prefix makes it
# available in browser-side code.
NEXT_PUBLIC_FASTAPI_BASE_URL=http://127.0.0.1:8000

# URL for the "Book call" button in the account detail panel.
# Replace with your real Calendly or scheduling link.
NEXT_PUBLIC_BOOKING_URL=https://calendly.com/your-link
